setopt hashexecutablesonly
export j() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
	/bin/rm -f -- "$tmp"
}
dj() {
  dirs -v
  read var
  if [[ -n $var ]]; then
    pushd -$var
  fi
  unset var
}
rm(){
for i in ${@}; do
  trash-put "${i}"
done
unset i
}
m(){
  if [[ $1 == '-h' ]];then
    echo "e.g.        m script.sh bash"
    return 0
  fi
  if [[ -f "${1}"  ]];then
    echo file exists
    return 1
    else 
    echo "#!/usr/bin/env ${2}" > "${1}"
    chmod u+x ${1}
      if [[ $3 == 'v' ]];then

      v "$1"
      fi
  fi
}
# Save current directory on exit
chpwd() { pwd >! ~/.last_dir }

# Change to last directory on startup
if [[ -f ~/.last_dir ]]; then
    cd "$(cat ~/.last_dir)" || cd ~
fi
